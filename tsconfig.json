{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": "src",
    "paths": {
      "@/*": ["./*"],
      "shared/*": ["shared/*"],
    },
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "./src/uniwind-types.d.ts",
  ],
  "exclude": [
    "node_modules",
    "app-example",
  ],
}
